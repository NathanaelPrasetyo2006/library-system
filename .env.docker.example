# Template .env untuk deploy via Docker di VPS.
# Copy file ini jadi ".env" di root project (sejajar dengan docker-compose.yml),
# lalu isi/ubah nilai yang ditandai "WAJIB DIISI" sebelum menjalankan `docker compose up -d`.

APP_NAME=Perpustakaan
APP_ENV=production
# WAJIB DIISI: generate sekali secara lokal dengan `php artisan key:generate --show`
# lalu tempel hasilnya di sini (base64:....). Jangan biarkan kosong.
APP_KEY=
APP_DEBUG=false
# WAJIB DIISI: domain/IP VPS yang sebenarnya, contoh https://perpustakaan.example.com
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# DB_HOST harus "db" (nama service MySQL di docker-compose.yml), bukan 127.0.0.1
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=perpustakaan
DB_USERNAME=root
# WAJIB DIISI: password root MySQL, dipakai juga sebagai MYSQL_ROOT_PASSWORD oleh
# service "db" di docker-compose.yml. Jangan dikosongkan untuk production.
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Tidak dipakai saat ini (cache/session/queue semuanya "database"), disertakan
# hanya untuk kompatibilitas config bawaan Laravel. Tidak ada container Redis.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# MAIL_MAILER=log artinya email (verifikasi akun, reset password) hanya
# ditulis ke storage/logs, tidak benar-benar terkirim. Ganti ke smtp +
# isi kredensial di bawah kalau fitur email dipakai di production.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
